{
  "id": "openclaw",
  "name": "agenticmail",
  "version": "0.5.61",
  "displayName": "🎀 AgenticMail",
  "description": "🎀 AgenticMail — 63 tools for email, SMS, storage & multi-agent coordination",
  "author": "agenticmail",
  "license": "MIT",
  "homepage": "https://github.com/agenticmail/agenticmail",

  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "AgenticMail API URL",
        "default": "http://127.0.0.1:3100"
      },
      "apiKey": {
        "type": "string",
        "description": "Agent API key for authentication"
      },
      "masterKey": {
        "type": "string",
        "description": "Master API key for admin operations (optional)"
      },
      "inboxInjectionMode": {
        "type": "string",
        "description": "Unread inbox context injection mode: off disables it, count shows only unread count, summary shows metadata summaries, required forces agents to read unread mail first",
        "enum": ["off", "count", "summary", "required"],
        "default": "summary"
      },
      "inboxInjectionMaxItems": {
        "type": "integer",
        "description": "Maximum unread messages to summarize in prompt context",
        "minimum": 1,
        "maximum": 25,
        "default": 5
      },
      "inboxInjectionIncludePreview": {
        "type": "boolean",
        "description": "Include a short body preview in unread message summaries",
        "default": false
      },
      "spawnMinTimeoutSeconds": {
        "type": "integer",
        "description": "Minimum runTimeoutSeconds to enforce for sessions_spawn calls; set to 0 to disable timeout changes",
        "minimum": 0,
        "default": 600
      }
    },
    "required": ["apiKey"]
  },
  "tools": [
    "agenticmail_send",
    "agenticmail_inbox",
    "agenticmail_read",
    "agenticmail_search",
    "agenticmail_import_relay",
    "agenticmail_delete",
    "agenticmail_reply",
    "agenticmail_forward",
    "agenticmail_move",
    "agenticmail_mark_unread",
    "agenticmail_mark_read",
    "agenticmail_folders",
    "agenticmail_list_folder",
    "agenticmail_create_folder",
    "agenticmail_batch_read",
    "agenticmail_batch_delete",
    "agenticmail_batch_mark_read",
    "agenticmail_batch_mark_unread",
    "agenticmail_batch_move",
    "agenticmail_digest",
    "agenticmail_template_send",
    "agenticmail_list_agents",
    "agenticmail_message_agent",
    "agenticmail_check_messages",
    "agenticmail_wait_for_email",
    "agenticmail_check_tasks",
    "agenticmail_claim_task",
    "agenticmail_submit_result",
    "agenticmail_complete_task",
    "agenticmail_call_agent",
    "agenticmail_contacts",
    "agenticmail_drafts",
    "agenticmail_signatures",
    "agenticmail_templates",
    "agenticmail_schedule",
    "agenticmail_tags",
    "agenticmail_rules",
    "agenticmail_spam",
    "agenticmail_pending_emails",
    "agenticmail_whoami",
    "agenticmail_update_metadata",
    "agenticmail_create_account",
    "agenticmail_delete_agent",
    "agenticmail_deletion_reports",
    "agenticmail_cleanup",
    "agenticmail_status",
    "agenticmail_setup_relay",
    "agenticmail_setup_domain",
    "agenticmail_purchase_domain",
    "agenticmail_gateway_status",
    "agenticmail_test_email",
    "agenticmail_setup_guide",
    "agenticmail_setup_gmail_alias",
    "agenticmail_setup_payment",
    "agenticmail_sms_setup",
    "agenticmail_sms_send",
    "agenticmail_sms_messages",
    "agenticmail_sms_check_code",
    "agenticmail_sms_read_voice",
    "agenticmail_sms_record",
    "agenticmail_sms_parse_email",
    "agenticmail_sms_config",
    "agenticmail_storage"
  ],
  "requires": {
    "bins": ["docker"]
  }
}
