{
  "name": "@agenticmail/core",
  "version": "0.9.0",
  "description": "Core SDK for AgenticMail — email, SMS, and phone number access for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "REFERENCE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "imapflow": "^1.0.170",
    "mailparser": "^3.7.2",
    "nodemailer": "^8.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agenticmail/agenticmail.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/agenticmail/agenticmail",
  "bugs": "https://github.com/agenticmail/agenticmail/issues",
  "keywords": [
    "email",
    "sms",
    "phone",
    "ai",
    "agent",
    "mail",
    "smtp",
    "imap",
    "agenticmail",
    "ai-agent",
    "mcp",
    "google-voice",
    "text-message"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Ope Olatunji",
  "license": "MIT"
}
