{
  "name": "agenticmail-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "agenticmail"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:mcp && npm run build:api && npm run build:claudecode && npm run build:codex && npm run build:openclaw && npm run build:cli",
    "build:core":       "npm run build --workspace=@agenticmail/core --if-present",
    "build:mcp":        "npm run build --workspace=@agenticmail/mcp --if-present",
    "build:api":        "npm run build --workspace=@agenticmail/api --if-present",
    "build:claudecode": "npm run build --workspace=@agenticmail/claudecode --if-present",
    "build:codex":      "npm run build --workspace=@agenticmail/codex --if-present",
    "build:openclaw":   "npm run build --workspace=@agenticmail/openclaw --if-present",
    "build:cli":        "npm run build --workspace=@agenticmail/cli --if-present",
    "build:all":        "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:api": "npm run dev --workspace=@agenticmail/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "init": "tsx scripts/init-local.ts",
    "setup": "node agenticmail/dist/cli.js setup",
    "start": "node agenticmail/dist/cli.js start",
    "status": "node agenticmail/dist/cli.js status"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Ope Olatunji",
  "license": "MIT",
  "description": "Email and SMS infrastructure for AI agents — the first platform to give agents real email addresses and phone numbers",
  "keywords": [
    "email",
    "sms",
    "phone",
    "ai",
    "agent",
    "agenticmail",
    "google-voice"
  ],
  "dependencies": {
    "@types/nodemailer": "^7.0.10"
  },
  "overrides": {
    "nodemailer": "9.0.3",
    "esbuild": "0.28.1"
  },
  "version": "0.0.2"
}
